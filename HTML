<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Workshop Management Pro</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<style>
:root { --p: #2563eb; --bg: #0f172a; --card: #1e293b; --accent: #38bdf8; }

body {
    font-family: 'Poppins', sans-serif;
    background: var(--bg);
    color: white;
    margin: 0;
    padding: 20px;
    text-align: center;
}

.container { max-width: 900px; margin: auto; }

header h1 {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 30px;
}

.veh-card {
    background: var(--card);
    border-radius: 20px;
    padding: 25px;
    margin-bottom: 30px;
    border-left: 8px solid var(--p);
    box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    align-items: center;
    text-align: left;
}

.veh-img {
    width: 280px;
    height: 190px;
    object-fit: cover;
    border-radius: 12px;
}

.details { flex: 1; }

.veh-title {
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 10px;
}

.info { margin: 8px 0; }

.btn, .btn2 {
    margin-top: 10px;
    padding: 8px 14px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 13px;
}

.btn { background: #22c55e; color: white; }
.btn2 { background: #f59e0b; color: black; }

.history, .qr-box {
    display: none;
    margin-top: 15px;
}

.qr-box {
    background: white;
    padding: 10px;
    border-radius: 10px;
    width: fit-content;
}
</style>
</head>

<body>

<div class="container">
<header><h1>🛠️ Workshop Dashboard</h1></header>

<!-- VEH 916 -->
<div class="veh-card" id="veh916">
<img src="916.jpg" class="veh-img">

<div class="details">
<div class="veh-title">VEH NO: 916 (Armado)</div>

<div class="info">Last Service: <b class="last-service">2026-07-26</b></div>
<div class="info">Next Service: <b class="next-service"></b></div>

<button onclick="toggleQR('veh916')" class="btn">View QR</button>
<button onclick="toggleHistory('veh916')" class="btn2">Vehicle History</button>

<div class="history">
<strong>LAST DEFECTS:</strong>
<p>(1) Transmission software update<br>(2) Transmission oil change</p>
</div>

<div class="qr-box">
<div id="qr916"></div>
</div>

</div>
</div>

<!-- VEH 917 -->
<div class="veh-card" id="veh917">
<img src="917.jpg" class="veh-img">

<div class="details">
<div class="veh-title">VEH NO: 917</div>

<div class="info">Last Service: <b class="last-service">2026-07-12</b></div>
<div class="info">Next Service: <b class="next-service"></b></div>

<button onclick="toggleQR('veh917')" class="btn">View QR</button>
<button onclick="toggleHistory('veh917')" class="btn2">Vehicle History</button>

<div class="history">
<strong>LAST DEFECTS:</strong>
<p>(1) Transmission oil change<br>(2) Battery new fitted</p>
</div>

<div class="qr-box">
<div id="qr917"></div>
</div>

</div>
</div>

</div>

